# ─────────────────────────────────────────────────────────────
# InsightDocket — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Google AI ──────────────────────────────────────────────────
# Gemini free tier: 15 RPM, 1M tokens/day
# Get key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ── LangSmith Observability ────────────────────────────────────
# Free tier at: https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=insightdocket
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── MongoDB ────────────────────────────────────────────────────
# Docker container — directConnection=true (no replica set)
MONGODB_URI=mongodb://server:password@localhost:27017/?authSource=admin&directConnection=true
MONGODB_DATABASE=insightdocket
MONGODB_COLLECTION=chunks
# Vector index name created via MongoDB shell (see README)
MONGODB_VECTOR_INDEX=vector_index

# ── MySQL ──────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=insightdocket
MYSQL_PASSWORD=insightdocket_pass
MYSQL_DATABASE=insightdocket
# Full async DSN constructed from above in config.py
# mysql+aiomysql://user:pass@host:port/db

# ── Application ────────────────────────────────────────────────
APP_ENV=development          # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO

# ── Storage ────────────────────────────────────────────────────
# Local folder used as PDF storage (S3-compatible interface)
PDF_STORAGE_PATH=./storage/pdfs

# ── Rate Limiting ──────────────────────────────────────────────
# Gemini free tier hard cap — do NOT increase beyond 15
GEMINI_RPM_LIMIT=5
# Embedding batch size (chunks sent per API call)
EMBEDDING_BATCH_SIZE=10

# ── RAG Tuning ─────────────────────────────────────────────────
# Minimum confidence score to return an answer (0.0 – 1.0)
CONFIDENCE_THRESHOLD=0.35
# Number of chunks retrieved from vector search
VECTOR_TOP_K=20
# Number of chunks retrieved from BM25 text search
TEXT_TOP_K=20
# Final chunks passed to LLM after RRF + reranking
FINAL_TOP_K=5

# ── Reranker ───────────────────────────────────────────────────
# Local cross-encoder model — downloaded once, cached in ~/.cache
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Security ───────────────────────────────────────────────────
# JWT secret for internal signing (not used for API key auth)
SECRET_KEY=change_this_to_a_long_random_string_in_production
# API keys are SHA-256 hashed before storage — raw key only shown once at creation
API_KEY_HEADER=X-API-Key

# ── Audit Logs ─────────────────────────────────────────────────
AUDIT_LOG_DIR=./logs
